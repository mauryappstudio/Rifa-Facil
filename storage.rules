rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /vouchers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*|application/pdf');
    }
  }
}
