rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Config: solo admin escribe, todos leen
    match /rifas/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Números: cualquiera puede leer, escribir si el número está libre o si es admin
    match /numeros/{numero} {
      allow read: if true;
      allow create: if request.resource.data.estado == 'reservado';
      allow update, delete: if request.auth != null;
    }
  }
}
